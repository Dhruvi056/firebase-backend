rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "super_admin";
    }

    // Forms collection - users can only access their own forms
    match /forms/{formId} {
      allow read, list, write: if request.auth != null && (isSuperAdmin() || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && (isSuperAdmin() || request.auth.uid == request.resource.data.userId);
      
      // Allow read/write access to submissions subcollection (public for form submissions)
      match /submissions/{submissionId} {
        allow read, list: if request.auth != null && (isSuperAdmin() || request.auth.uid == get(/databases/$(database)/documents/forms/$(formId)).data.userId);
        allow write: if true; // Allow form submissions from webflow
      }
    }
    
    // Folders collection - users can only access their own folders
    match /folders/{folderId} {
      allow read, list, write: if request.auth != null && (isSuperAdmin() || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && (isSuperAdmin() || request.auth.uid == request.resource.data.userId);
    }

    // Users collection - super admin can view platform users
    match /users/{userId} {
      allow read, list, write: if request.auth != null && (isSuperAdmin() || request.auth.uid == userId);
    }
  }
}

